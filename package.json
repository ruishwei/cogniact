{
  "name": "cloud-agent-browser",
  "version": "1.0.0",
  "description": "Cloud-based intelligent agent browser system with multi-user support",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --watch server server/index.js",
