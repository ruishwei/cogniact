    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.1",
    "playwright-core": "^1.40.1",
    "ws": "^8.14.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "node-cron": "^3.0.3",
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "jszip": "^3.10.1",
    "openai": "^4.24.1",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "marked": "^11.1.1",
    "highlight.js": "^11.9.0"
